{
  "manifestVersion": 1,
  "id": "ado-cost-rollup-widget",
  "version": "1.0.0",
  "name": "ADO Cost Roll-Up Widget",
  "publisher": "deenuy",
  "description": "Dashboard widget that aggregates work items by any string-like field and sums a numeric field as formatted currency.",
  "categories": ["Azure Boards"],
  "scopes": ["vso.work"],
  "icons": { "default": "marketplace/logo.png" },
  "targets": [
    { "id": "Microsoft.VisualStudio.Services.Cloud" },
    { "id": "Microsoft.TeamFoundation.Server", "version": "[15.0,)" }
  ],
  "public": true,
  "tags": ["Dashboard", "Widget", "Cost", "Budget", "Roll-up", "Aggregate", "Portfolio", "PMO"],
  "branding": { "color": "rgb(0, 120, 212)", "theme": "dark" },
  "content": {
    "details": { "path": "marketplace/overview.md" },
    "license": { "path": "LICENSE.md" }
  },
  "galleryFlags": ["Public"],
  "repository": {
    "type": "git",
    "uri": "https://github.com/deenuy/ado-cost-rollup-widget"
  },
  "links": {
    "support": {
      "uri": "https://github.com/deenuy/ado-cost-rollup-widget/issues"
    },
    "privacy": {
      "uri": "https://github.com/deenuy/ado-cost-rollup-widget/blob/main/PRIVACY.md"
    }
  },
  "files": [
    { "path": "marketplace/overview.md", "addressable": true },
    { "path": "marketplace/logo.png",    "addressable": true },
    { "path": "LICENSE.md",              "addressable": true },
    { "path": "dist",                    "addressable": true },
    { "path": "src/static",              "addressable": true, "packagePath": "static" },
    { "path": "node_modules/vss-web-extension-sdk/lib", "addressable": true, "packagePath": "lib" }
  ],
  "contributions": [
    {
      "id": "cost-rollup-widget",
      "type": "ms.vss-dashboards-web.widget",
      "targets": [
        "ms.vss-dashboards-web.widget-catalog",
        ".cost-rollup-widget-Configuration"
      ],
      "properties": {
        "name": "Cost Roll-Up",
        "description": "Group work items by a field and sum a numeric field as currency.",
        "uri": "static/widget.html",
        "isNameConfigurable": true,
        "catalogIconUrl": "marketplace/logo.png",
        "previewImageUrl": "marketplace/logo.png",
        "supportedSizes": [
          { "rowSpan": 2, "columnSpan": 2 },
          { "rowSpan": 2, "columnSpan": 3 },
          { "rowSpan": 2, "columnSpan": 4 },
          { "rowSpan": 3, "columnSpan": 3 },
          { "rowSpan": 3, "columnSpan": 4 },
          { "rowSpan": 3, "columnSpan": 5 },
          { "rowSpan": 4, "columnSpan": 4 },
          { "rowSpan": 4, "columnSpan": 5 }
        ],
        "supportedScopes": ["project_team"]
      }
    },
    {
      "id": "cost-rollup-widget-Configuration",
      "type": "ms.vss-dashboards-web.widget-configuration",
      "targets": ["ms.vss-dashboards-web.widget-configuration"],
      "properties": {
        "name": "Cost Roll-Up Configuration",
        "description": "Pick a query, group-by field, and aggregate field.",
        "uri": "static/configuration.html"
      }
    }
  ]
}